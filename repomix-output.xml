    session: Session = Depends(get_session),
    current_user=Depends(admin_required)
):
    if not confirm:
        raise HTTPException(status_code=status.HTTP_400_BAD_REQUEST, detail="Подтвердите удаление: ?confirm=true")
    delete_all_flights(session)
